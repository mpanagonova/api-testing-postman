          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "pm.test(\"Response body has required attributes\", function(){",
              "    var responseBody = pm.response.json();",
              "    pm.expect(responseBody).to.have.property('email');",
              "    pm.expect(responseBody).to.have.property('password');",
              "    pm.expect(responseBody).to.have.property('accessToken');",
              "})",
              "",
              "pm.collectionVariables.set(\"token\", pm.response.json().accessToken); "
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
