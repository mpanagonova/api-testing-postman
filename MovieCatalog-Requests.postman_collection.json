    {
      "name": "Create a New Movie",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const movies = [\"Echo\", \"Drift\", \"Signal\", \"Fragments\", \"Afterlight\", \"Pulse\", \"Static\", \"Fade\"];",
              "const randomMovie = movies[Math.floor(Math.random() * movies.length)];",
              "const randomNumber = Math.floor(Math.random() * 1000);",
              "const randomTitle = randomMovie + '' + randomNumber;",
              "",
              "pm.collectionVariables.set(\"randomTitle\", randomTitle);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success message\", function() {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson.msg).to.eql(\"Movie created successfully!\")",
              "})",
              "",
              "pm.test(\"Title and description match request\", function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson.movie.title).to.eql(pm.collectionVariables.get(\"randomTitle\"));",
              "    pm.expect(responseJson.movie.description).to.eql(\"Movie created successfully!\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n\"title\": \"{{randomTitle}}\",\n\"description\": \"Movie created successfully!\",\n\"posterUrl\": \"\",\n\"trailerLink\": \"\",\n\"isWatched\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/api/Movie/Create",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "api",
            "Movie",
            "Create"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List all Movies",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "pm.test(\"Response is an array with at least one movie\", function(){",
              "    var responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an('array').that.is.not.empty;",
              "})",
              "",
              "pm.test(\"Extract ID of the last created movie\", function (){",
              "    var responseDATA = pm.response.json();",
              "    var lastMovie = responseDATA[responseDATA.length - 1]",
              "    var lastMovieID = lastMovie.id",
              "    pm.collectionVariables.set(\"lastMovieID\", lastMovieID)",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [],
            "type": "text/javascript"
          }
        }
      ],
