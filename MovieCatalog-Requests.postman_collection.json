    {
      "name": "Edit the Last Movie",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "})",
              "",
              "var responseJson = pm.response.json();",
              "",
              "pm.test(\"Movie edited successfully message is returned\", function () {",
              "    pm.expect(responseJson.msg).to.eql(\"Movie edited successfully!\");",
              "})",
              "",
              "pm.test(\"Title is correctly changed\", function () {",
              "    pm.expect(responseJson.movie.title).to.eql(\"PostStatic345\")",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
